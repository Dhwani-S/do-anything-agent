# Secrets — NEVER commit
.env
.env.local

# Local runtime state — regenerated on each run
.plan/
.venv/
src/state/sessions/*/
!src/state/sessions/.gitkeep
src/state/memory.json
src/state/index.faiss
src/state/index_ids.json
src/sandbox/*.txt
gateway/.venv/
gateway/*.db
gateway/usage.json

# Build / cache artifacts
**/__pycache__/
**/*.pyc
**/uv.lock
**/.pytest_cache/

# Editors
.vscode/
.idea/
.DS_Store
